APP_URL="https://www.lamour.com.vn"

# Telegram Bot — nhận notification tức thì khi có khách hàng mới
# 1. Nhắn tin @BotFather trên Telegram → /newbot → lấy token
# 2. Nhắn tin @userinfobot để lấy chat_id của bạn
TELEGRAM_BOT_TOKEN="123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TELEGRAM_CHAT_ID="123456789"

# Resend — gửi email thông báo
# Đăng ký tại https://resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
# Email nhận thông báo (hộp thư của bạn)
OWNER_EMAIL="your@email.com"
# Email gửi đi — phải verify domain tại Resend dashboard
# (dùng onboarding@resend.dev để test trước khi verify domain)
RESEND_FROM_EMAIL="noreply@lamour.com.vn"
